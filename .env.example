# ========================================
# Database (PostgreSQL)
# ========================================
DB_NAME=greenify_db
DB_USER=greenify_user
DB_PASSWORD=change_in_production

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your-256-bit-secret-key-here

# ========================================
# Google OAuth2
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# Goong Reverse Geocoding
# ========================================
GOONG_API_KEY=your-goong-api-key

# ========================================
# Mail (Gmail SMTP)
# ========================================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ========================================
# CORS / Frontend URL
# ========================================
DOMAIN_URL=http://localhost:3000

# ========================================
# Unsplash Image Source
# ========================================
UNSPLASH_ENABLED=true
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
UNSPLASH_SECRET_KEY=your-unsplash-secret-key
UNSPLASH_BASE_URL=https://api.unsplash.com
UNSPLASH_TIMEOUT_MILLIS=3000
UNSPLASH_CACHE_SIZE=20
UNSPLASH_SEARCH_PER_PAGE=30
UNSPLASH_ORIENTATION=landscape
UNSPLASH_CONTENT_FILTER=high
UNSPLASH_MIN_WIDTH=1000
UNSPLASH_MIN_HEIGHT=700
UNSPLASH_MIN_LIKES=10
